# === シークレット（絶対にコミットしない） ===
.env
.env.*
!.env.example
config/master.key
config/credentials/*.key
*.pem

# === 個人設定（共有しない） ===
CLAUDE.local.md
.claude/settings.local.json

# === 依存・ビルド成果物 ===
node_modules/
.next/
out/
dist/
build/
tmp/
log/
*.log

# === Rails ===
/db/*.sqlite3
/db/*.sqlite3-*
/storage/

# === Python / FastAPI ===
__pycache__/
*.py[cod]
.venv/
venv/

# === モノレポ（src/ 配下の各サービス）: シークレット・生成物を多重防御で除外 ===
# シークレット（ネスト配下も確実に除外）
src/**/config/master.key
src/**/config/credentials/*.key
# SQLite（Rails。デモ版固定DB）
src/**/db/*.sqlite3
src/**/db/*.sqlite3-*
# アップロード画像・生成PDF（F7 日次リセット対象。コミットしない）
src/**/uploads/
src/**/storage/
uploads/
# Next.js
src/**/.next/
src/**/node_modules/

# === OS / エディタ ===
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# === 追跡するのは CLAUDE.md / README.md / SPEC/ のみ ===
# 上記3点以外の直下エントリを明示的に除外する（後勝ちルールで .env.example も除外）
.claude/
CLIENT/
DEBUG/
DELETE/
ENV/
TASKS/
WORK/
app-ui/
test/
freelance-receipt-organizer-demo_設計書.md
# ルートの図解ツール用 package.json のみ無視する（フロントの src/web/package.json は追跡する）。
/package.json
/package-lock.json
.vercel
