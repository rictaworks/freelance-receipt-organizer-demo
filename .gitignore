config/master.key
config/credentials/*.key
*.pem

# === 個人設定（共有しない） ===
CLAUDE.local.md
.claude/settings.local.json

# === 依存・ビルド成果物 ===
node_modules/
.next/
out/
dist/
build/
tmp/
log/
*.log

# === Rails ===
/db/*.sqlite3
/db/*.sqlite3-*
/storage/

# === Python / FastAPI ===
__pycache__/
*.py[cod]
.venv/
venv/

# === OS / エディタ ===
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

