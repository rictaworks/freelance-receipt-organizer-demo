# 開発環境の環境変数雛形（ENV/DEVELOPMENT.md）。実値は .env に置きコミットしない。
APP_ENV=development
TZ=Asia/Tokyo
RAILS_ENV=development

# バックエンド Rails API はポート 4000。
PORT=4000

# OCR サービス（FastAPI）。Rails からローカル間通信で呼ぶ。
OCR_SERVICE_URL=http://localhost:8000

# フロント（Next.js）のオリジン（CORS 許可先）。
FRONTEND_ORIGIN=http://localhost:3000

# 開発では認証をバイパスし「認証済み」に固定する。
DEV_AUTO_LOGIN=true

# シークレットは絶対にコミットしない（RAILS_MASTER_KEY 等はプラットフォーム変数で渡す）。
# RAILS_MASTER_KEY=
