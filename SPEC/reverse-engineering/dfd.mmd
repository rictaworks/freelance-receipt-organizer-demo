    D2[(D2 マスタ<br/>科目/ルール/辞書)]
    D3[(D3 画像<br/>ストレージ)]
    D4[(D4 reports)]
    CLK([スケジューラ])

    U -- 領収書画像 --> P1
    P1 -- 前処理済み画像 --> P2
    P1 -- 原本保存 --> D3
    P2 -- 日付/金額/店名 --> P3
    D2 -- キーワードルール --> P3
    P3 -- 分類済みレコード --> D1
    U -- 手動修正 --> D1
    D1 -- セッション内データ --> P4
    P4 -- 月×科目集計 --> P5
    D2 -- 帳票テンプレート --> P5
    P5 -- PDF --> D4
    P5 -- プレビュー/PDF --> U
    CLK -- 毎日03:00 --> P6
